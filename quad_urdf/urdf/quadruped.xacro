<?xml version="1.0" ?>
<robot name="quadruped" xmlns:xacro="http://www.ros.org/wiki/xacro">

<xacro:macro name="quadruped" params="prefix load_meta:=true">

<xacro:if value="${load_meta}">
  <xacro:include filename="$(find quad_urdf)/urdf/quadruped.trans" />
  <xacro:include filename="$(find quad_urdf)/urdf/quadruped.gazebo" />
</xacro:if>

<material name="atlas_blue">
  <color rgba="0.360 0.450 0.980 1.000"/>
</material>

<material name="atlas_dark_gray">
  <color rgba="0.125 0.135 0.145 1.000"/>
</material>

<link name="${prefix}base_link">
  <visual>
    <!-- Center the CAD-exported base mesh on the base_link frame. -->
    <origin xyz="-0.284511 -0.607414 0.007931" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://quad_urdf/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="atlas_blue"/>
  </visual>
  <collision>
    <origin xyz="-0.284511 -0.607414 0.007931" rpy="0 0 0"/>
