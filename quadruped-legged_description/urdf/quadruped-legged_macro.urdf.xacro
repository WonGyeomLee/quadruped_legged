<?xml version="1.0" ?>
<robot name="quadruped-legged" xmlns:xacro="http://www.ros.org/wiki/xacro">

<xacro:macro name="quadruped-legged" params="prefix load_meta:=true">

<xacro:if value="${load_meta}">
  <xacro:include filename="$(find quadruped-legged_description)/urdf/materials.xacro" />
  <xacro:include filename="$(find quadruped-legged_description)/urdf/quadruped-legged.trans" />
  <xacro:include filename="$(find quadruped-legged_description)/urdf/quadruped-legged.gazebo" />
</xacro:if>

<material name="quadruped-legged_silver">
  <color rgba="0.700 0.700 0.700 1.000"/>
</material>

<link name="${prefix}base_link">
  <visual>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://quadruped-legged_description/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="quadruped-legged_silver"/>
  </visual>
  <collision>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://quadruped-legged_description/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

<link name="${prefix}fr_hip">
  <inertial>
    <origin xyz="0.022406190093623463 0.00586523166196927 -0.011025872454559518" rpy="0 0 0"/>
    <mass value="0.4402757419432753"/>
    <inertia ixx="0.000129" iyy="0.000143" izz="9.8e-05" ixy="-1e-06" iyz="0.0" ixz="1e-06"/>
  </inertial>
  <visual>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://quadruped-legged_description/meshes/fr_hip.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="quadruped-legged_silver"/>
  </visual>
  <collision>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://quadruped-legged_description/meshes/fr_hip.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

<link name="${prefix}fr_leg">
  <inertial>
    <origin xyz="-0.10447162313529515 0.06770905838104065 -0.006451266657444209" rpy="0 0 0"/>
    <mass value="0.8819417369199037"/>
    <inertia ixx="0.001238" iyy="0.001149" izz="0.000203" ixy="2e-06" iyz="4.9e-05" ixz="-1.1e-05"/>
  </inertial>
  <visual>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://quadruped-legged_description/meshes/fr_leg.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="quadruped-legged_silver"/>
  </visual>
  <collision>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://quadruped-legged_description/meshes/fr_leg.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

<link name="${prefix}fr_foot">
  <inertial>
    <origin xyz="-0.07886008449279897 0.08956646074386246 -0.012679618798696626" rpy="0 0 0"/>
    <mass value="0.4701549157206575"/>
    <inertia ixx="0.00096" iyy="0.000946" izz="7e-05" ixy="-3e-06" iyz="-1.6e-05" ixz="-1.7e-05"/>
  </inertial>
  <visual>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://quadruped-legged_description/meshes/fr_foot.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="quadruped-legged_silver"/>
  </visual>
  <collision>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://quadruped-legged_description/meshes/fr_foot.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

<joint name="${prefix}fr_i_hip" type="continuous">
  <origin xyz="-0.102 0.040896 0.034274" rpy="0.0 -0.0 0.0"/>
  <parent link="${prefix}base_link"/>
  <child link="${prefix}fr_hip"/>
  <axis xyz="1.0 0.0 0.0"/>
</joint>

<joint name="${prefix}fr_o_hip" type="continuous">
  <origin xyz="0.022207 0.027211 -0.011113" rpy="0.0 -0.0 0.0"/>
  <parent link="${prefix}fr_hip"/>
  <child link="${prefix}fr_leg"/>
  <axis xyz="-0.0 1.0 0.0"/>
</joint>

<joint name="${prefix}fr_knee" type="continuous">
  <origin xyz="-0.01513 0.0022 -0.107733" rpy="0.0 -0.0 0.0"/>
  <parent link="${prefix}fr_leg"/>
  <child link="${prefix}fr_foot"/>
  <axis xyz="-0.0 1.0 0.0"/>
</joint>

</xacro:macro>

<xacro:quadruped-legged prefix="" load_meta="false" />

</robot>
